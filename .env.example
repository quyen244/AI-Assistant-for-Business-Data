# ============================================
# LLM Configuration
# ============================================

# OpenAI GPT Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4  # or gpt-3.5-turbo for cost-effective option
OPENAI_TEMPERATURE=0.3

# Google Gemini Configuration
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-pro

# Default LLM Provider (gpt or gemini)
DEFAULT_LLM_PROVIDER=gpt

# ============================================
# Database Configuration
# ============================================

# Database URL (SQLite or PostgreSQL)
# SQLite example:
DATABASE_URL=sqlite:///./data/business_data.db

# PostgreSQL example (if using PostgreSQL instead):
# DATABASE_URL=postgresql://user:password@localhost:5432/business_data

# Database Settings
DATABASE_ECHO=False  # Set to True for SQL query logging
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ============================================
# API Configuration
# ============================================

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False
API_RELOAD=True  # Set to False in production

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]
CORS_CREDENTIALS=True
CORS_METHODS=["GET", "POST", "PUT", "DELETE"]
CORS_HEADERS=["*"]

# ============================================
# Application Configuration
# ============================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Application Name
APP_NAME=AI Assistant for Business Data
APP_VERSION=1.0.0

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Query Timeout (in seconds)
QUERY_TIMEOUT=30

# Max Rows in Response
MAX_RESPONSE_ROWS=1000

# ============================================
# Security Configuration
# ============================================

# Secret Key for session management
SECRET_KEY=your_secret_key_here_change_in_production

# JWT Settings (if needed)
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Streamlit Configuration
# ============================================

# Streamlit Server Settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_LOGGER_LEVEL=info

# ============================================
# LLM Safety and Rate Limiting
# ============================================

# Maximum tokens for SQL generation
MAX_TOKENS=1000

# Rate limiting
RATE_LIMIT_QUERIES_PER_MINUTE=60
RATE_LIMIT_DATA_UPLOADS_PER_HOUR=20

# ============================================
# Data Processing
# ============================================

# Maximum file size for upload (in MB)
MAX_UPLOAD_FILE_SIZE=50

# Allowed file formats
ALLOWED_FILE_FORMATS=csv,xlsx,xls

# ============================================
# Feature Flags
# ============================================

# Enable/disable features
ENABLE_QUERY_HISTORY=True
ENABLE_QUERY_CACHING=True
ENABLE_DATA_VALIDATION=True
ENABLE_API_METRICS=True

# ============================================
# Caching
# ============================================

# Cache Settings
CACHE_ENABLED=True
CACHE_TTL_SECONDS=300  # 5 minutes

# ============================================
# Monitoring and Alerting
# ============================================

# Error Tracking (optional)
# SENTRY_DSN=your_sentry_dsn_here

# Analytics (optional)
# ANALYTICS_ENABLED=False
